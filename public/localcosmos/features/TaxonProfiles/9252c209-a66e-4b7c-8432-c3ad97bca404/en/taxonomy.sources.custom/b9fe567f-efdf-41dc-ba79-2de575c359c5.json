    "texts": [
        {
            "taxonTextType": "Identification features",
            "shortText": "<p>Forms stiff, erect, tree-like growths arising from a small, disc-like holdfast.&nbsp; Axes cylindrical to slightly oval, branch in all directions and are constricted at irregular intervals. Colour dark red to blackish.</p>",
            "shortTextKey": "taxon_text_1_10330",
            "longText": null,
            "longTextKey": null,
            "images": []
        },
        {
            "taxonTextType": "Adult size",
            "shortText": "<p>Clumps up to about 150 mm tall. Axes 1-2 mm wide.</p>",
            "shortTextKey": "taxon_text_2_10331",
            "longText": null,
            "longTextKey": null,
            "images": []
        },
        {
            "taxonTextType": "Distribution",
            "shortText": "<p><u>Global:</u> Southern Australia and southern Africa.</p><p><u>Local/Regional</u><i><u>:</u> </i>Namibia to Eastern Cape.</p>",
            "shortTextKey": "taxon_text_3_10332",
            "longText": null,
            "longTextKey": null,
            "images": []
        },
        {
            "taxonTextType": "Biology",
            "shortText": "<p>Low intertidal pools and gullies and in shallow subtidal zone.</p>",
            "shortTextKey": "taxon_text_4_10333",
            "longText": null,
            "longTextKey": null,
            "images": []
        },
        {
            "taxonTextType": "Food / prey",
            "shortText": "<p>Photosynthetic.</p>",
            "shortTextKey": "taxon_text_5_10334",
            "longText": null,
            "longTextKey": null,
            "images": []
        },
        {
            "taxonTextType": "Reproduction",
            "shortText": "<p>Spore producing structures (tetrasporangia) towards the ends of the main uprights.</p>",
            "shortTextKey": "taxon_text_6_10335",
            "longText": null,
            "longTextKey": null,
            "images": []
        },
        {
            "taxonTextType": "Similar species",
            "shortText": "<p>Dark colour and branching pattern fairly distinctive.</p>",
            "shortTextKey": "taxon_text_7_10336",
            "longText": null,
            "longTextKey": null,
            "images": []
        },
        {
            "taxonTextType": "Further reading / References",
