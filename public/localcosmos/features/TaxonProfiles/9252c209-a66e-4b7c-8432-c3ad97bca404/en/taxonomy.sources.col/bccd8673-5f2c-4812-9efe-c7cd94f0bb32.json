        {
            "taxonTextType": "Similar species",
            "shortText": "<p>The laterally compressed body, blunt steeply-sloping head, and large crest on the dorsal fin readily identify this species.&nbsp;</p>",
            "shortTextKey": "taxon_text_7_3512",
            "longText": null,
            "longTextKey": null,
