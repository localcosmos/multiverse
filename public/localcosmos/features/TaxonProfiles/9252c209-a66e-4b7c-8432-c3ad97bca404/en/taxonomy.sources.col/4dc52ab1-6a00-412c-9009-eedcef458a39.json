                        "4x": "/localcosmos/user_content/content_images/image-3183-1000.webp"
                    }
                },
                {
                    "text": "",
                    "altText": "",
                    "title": "",
                    "imageUrl": {
                        "1x": "/localcosmos/user_content/content_images/image-3184-250.webp",
                        "2x": "/localcosmos/user_content/content_images/image-3184-500.webp",
                        "4x": "/localcosmos/user_content/content_images/image-3184-1000.webp"
                    }
                }
            ]
        },
        {
            "taxonTextType": "Food / prey",
            "shortText": "<p>Probably use a combination of filter and deposit feeding.</p>",
            "shortTextKey": "taxon_text_5_10373",
            "longText": null,
            "longTextKey": null,
            "images": []
        },
        {
            "taxonTextType": "Reproduction",
            "shortText": "<p>In this group sexes are separate and fertilization is external. Larval development may be either planktonic or benthic in different species.</p>",
            "shortTextKey": "taxon_text_6_10374",
            "longText": null,
            "longTextKey": null,
            "images": []
        },
        {
            "taxonTextType": "Similar species",
            "shortText": "<p>One of numerous small and easily confused species in this group (see account in reference below), but none of the closely-related species occur in the Western Cape. Superficially similar to Dunker's topshell <i>Cinysca dunkeri </i>but that species occurs intertidally while <i>P. articulata</i> occurs in deeper water.&nbsp;</p>",
            "shortTextKey": "taxon_text_7_10375",
            "longText": null,
            "longTextKey": null,
            "images": []
        }
    ],
